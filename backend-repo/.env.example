# Clerk authentication
CLERK_SECRET_KEY=your-clerk-secret-key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_OAUTH_REDIRECT_URI=https://advancedragpipeline.onrender.com/auth/github/callback

# Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_RAG_INDEX_NAME=rag-index
PINECONE_VECTOR_DIMENSION=1024
PINECONE_TEXT_FIELD=text
CODE_RETRIEVAL_TOP_K=8
CODE_RERANK_TOP_N=5

# AI providers and keys
COHERE_API_KEY=your-cohere-api-key
GROQ_API_KEY=your-groq-api-key

# Production / local app URLs
FRONTEND_APP_URL=https://advanced-rag-pipeline.vercel.app
FRONTEND_ORIGINS=https://advanced-rag-pipeline.vercel.app,http://localhost:5173
