# Clerk authentication
CLERK_SECRET_KEY=your-clerk-secret-key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_OAUTH_REDIRECT_URI=https://advancedragpipeline.onrender.com/auth/github/callback

# Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_RAG_INDEX_NAME=rag-index
PINECONE_PDF_INDEX_NAME=pdf-index
PINECONE_VECTOR_DIMENSION=1024
PINECONE_TEXT_FIELD=text
PDF_RETRIEVAL_TOP_K=30
PDF_RERANK_TOP_N=12

# AI providers and keys
COHERE_API_KEY=your-cohere-api-key
GROQ_API_KEY=your-groq-api-key
VOYAGEAI_API_KEY=your-voyage-api-key

# LlamaParse (for complex PDF parsing — bank statements, tables, etc.)
LLAMA_CLOUD_API_KEY=your-llama-cloud-api-key
LLAMA_PARSE_TIER=agentic
LLAMA_PARSE_VERSION=latest

# OCR.space (fallback for image-based PDFs under 1MB)
OCR_API_KEY=your-ocr-space-api-key

# Production / local app URLs
FRONTEND_APP_URL=https://advanced-rag-pipeline.vercel.app
FRONTEND_ORIGINS=https://advanced-rag-pipeline.vercel.app,http://localhost:5173
